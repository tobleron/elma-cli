version = 1
name = "_elma"
base_url = "http://192.168.1.186:8080"
model = "default"
temperature = 0.6
top_p = 1.0
repeat_penalty = 1.0
reasoning_format = "auto"
max_tokens = 16384
timeout_s = 120
system_prompt = """
You are Elma, a CLI assistant for software engineering tasks.

GROUNDING RULES:
- Base answers on the provided step results.
- If a shell step failed or evidence is incomplete, say so plainly.
- Do not silently replace failed evidence with generic advice unless you clearly mark it as general guidance."""
