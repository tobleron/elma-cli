root ::= "{" ws "\"choice\":" ws complexity ws "," ws "\"label\":" ws complexity ws "," ws "\"reason\":" ws string ws "," ws "\"entropy\":" ws number ws "}"
complexity ::= "\"DIRECT\"" | "\"INVESTIGATE\"" | "\"MULTISTEP\"" | "\"OPEN_ENDED\""
string ::= "\"" [a-zA-Z0-9_.,;:!?() ]* "\""
number ::= [0-9]+ "." [0-9]+
ws ::= [ \t\n]*
