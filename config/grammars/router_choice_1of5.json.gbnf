root ::= "{" ws "\"choice\":" ws choice ws "," ws "\"label\":" ws label ws "," ws "\"reason\":" ws string ws "," ws "\"entropy\":" ws number ws "}"
choice ::= "\"CHAT\"" | "\"INVESTIGATE\"" | "\"SHELL\"" | "\"PLAN\"" | "\"MASTERPLAN\""
label ::= "\"CHAT\"" | "\"INVESTIGATE\"" | "\"SHELL\"" | "\"PLAN\"" | "\"MASTERPLAN\""
string ::= "\"" [a-zA-Z0-9_.,;:!?() ]* "\""
number ::= [0-9]+ "." [0-9]+
ws ::= [ \t\n]*
