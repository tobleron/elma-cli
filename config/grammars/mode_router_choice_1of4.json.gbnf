root ::= "{" ws "\"choice\":" ws mode ws "," ws "\"label\":" ws mode ws "," ws "\"reason\":" ws string ws "," ws "\"entropy\":" ws number ws "}"
mode ::= "\"INSPECT\"" | "\"EXECUTE\"" | "\"PLAN\"" | "\"MASTERPLAN\""
string ::= "\"" [a-zA-Z0-9_.,;:!?() ]* "\""
number ::= [0-9]+ "." [0-9]+
ws ::= [ \t\n]*
